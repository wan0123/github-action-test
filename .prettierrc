{
    "overrides": [
        {
            "files": "*.js",
            "options": {
                "trailingComma": "es5",
                "printWidth": 80,
                "tabWidth": 4,
                "semi": true,
                "singleQuote": false,
                "bracketSpacing": false
            }
        },
        {
            "files": ["*.ts", "*.mts"],
            "options": {
                "trailingComma": "es5",
                "printWidth": 80,
                "tabWidth": 4,
                "semi": true,
                "singleQuote": false,
                "bracketSpacing": false
            }
        }
    ]
}